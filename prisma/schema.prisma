generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  studios       Studio[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Studio {
  id             String           @id @default(cuid())
  userId         String
  name           String
  website        String?
  logoUrl        String?
  brandColor     String           @default("#0f766e")
  contactEmail   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription?
  projects       WeddingProject[]
  events         EventLog[]
}

model Subscription {
  id                   String   @id @default(cuid())
  studioId             String   @unique
  plan                 String   @default("trial")
  status               String   @default("trialing")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  studio               Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model WeddingProject {
  id                    String                  @id @default(cuid())
  studioId              String
  coupleName1           String
  coupleName2           String
  weddingDate           DateTime?
  venueName             String?
  ceremonyLocation      String?
  receptionLocation     String?
  ceremonyTime          String?
  receptionTime         String?
  packageName           String?
  deliverablesJson      String                  @default("[]")
  vendorContactsJson    String                  @default("[]")
  musicPreferences      String?
  familyMembersJson     String                  @default("[]")
  mustHaveShotsJson     String                  @default("[]")
  restrictions          String?
  specialNotes          String?
  status                String                  @default("Draft")
  archived              Boolean                 @default(false)
  approvalToken         String                  @unique
  questionnaire         Questionnaire?
  responses             QuestionnaireResponse[]
  timelineItems         TimelineItem[]
  shotListItems         ShotListItem[]
  familyFormalGroups    FamilyFormalGroup[]
  briefDocuments        BriefDocument[]
  approvals             ClientApproval[]
  exports               ExportLog[]
  studio                Studio                  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
}

model Questionnaire {
  id          String         @id @default(cuid())
  projectId   String         @unique
  token       String         @unique
  title       String
  schemaJson  String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model QuestionnaireResponse {
  id         String         @id @default(cuid())
  projectId  String
  answersJson String
  submittedAt DateTime     @default(now())
  project    WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimelineItem {
  id               String         @id @default(cuid())
  projectId        String
  time             String
  title            String
  description      String?
  location         String?
  responsibleParty String?
  sortOrder        Int            @default(0)
  project          WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ShotListItem {
  id         String         @id @default(cuid())
  projectId  String
  section    String
  label      String
  notes      String?
  isMustHave Boolean        @default(false)
  sortOrder  Int            @default(0)
  project    WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model FamilyFormalGroup {
  id        String         @id @default(cuid())
  projectId String
  label     String
  people    String
  notes     String?
  sortOrder Int            @default(0)
  project   WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BriefDocument {
  id          String         @id @default(cuid())
  projectId   String
  type        String
  title       String
  contentJson String
  project     WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedAt   DateTime       @updatedAt

  @@unique([projectId, type])
}

model ClientApproval {
  id          String         @id @default(cuid())
  projectId   String
  status      String
  comments    String?
  approvedAt  DateTime?
  requestedAt DateTime?
  createdAt   DateTime       @default(now())
  project     WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExportLog {
  id        String         @id @default(cuid())
  projectId String
  type      String
  createdAt DateTime       @default(now())
  project   WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  studioId  String?
  type      String
  payload   String?
  createdAt DateTime @default(now())
  studio    Studio?  @relation(fields: [studioId], references: [id], onDelete: SetNull)
}
